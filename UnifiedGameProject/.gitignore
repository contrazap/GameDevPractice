# ============================================================================
#  UnifiedGameProject — UE 5.8 .gitignore
#  Scoped to this project folder (lives at UnifiedGameProject/.gitignore) so the
#  UE rules apply only to this subtree of the shared GameDevPractice repo.
#  Paths below are relative to THIS folder (e.g. "Binaries/" = UnifiedGameProject/Binaries/).
#  Based on Epic's current recommended UE ignore set, adapted from the EOS test.
# ============================================================================

# ---- Engine-generated directories (all regenerable; never commit) ----------
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/

# Plugin build output (regenerable) — keep the plugin's own Source/Content.
Plugins/**/Binaries/
Plugins/**/Intermediate/

# ---- IDE / editor project files (generated by GenerateProjectFiles) --------
.vs/
.vscode/
.idea/
# *.slnx is the new VS 2022 XML solution format (present in your generated project)
*.sln
*.slnx
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.xcodeproj
*.xcworkspace

# ---- Compiled binaries / intermediates -------------------------------------
*.obj
*.o
*.pch
*.gch
*.pdb
*.ipdb
*.iobj
*.exe
*.dll
*.dylib
*.so
*.a
*.lib
*.la
*.lai
*.lo
*.slo
*.app
*.ipa
*.out
*.mod

# ---- Precompiled source art (kept out of Content; source lives elsewhere) --
SourceArt/**/*.png
SourceArt/**/*.tga

# ---- Built lighting / navmesh data (regenerable on build) ------------------
*_BuiltData.uasset

# ============================================================================
#  SECRETS — filled in at Step 6 (your call, understand before adding).
#  When EOS keys land in P0.2 they go in real platform *Engine.ini files that
#  MUST NOT be committed; commit *.template copies instead. Uncomment then:
#
Config/Windows/WindowsEngine.ini
Config/Android/AndroidEngine.ini
# !Config/Windows/WindowsEngine.ini.template
# !Config/Android/AndroidEngine.ini.template
# ============================================================================
